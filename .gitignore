# Unity generated meta for excluded folders is okay (do not ignore *.meta globally!)

# Builds / archives / binaries (не хранить в репо)
*.apk
*.aab
*.exe
*.rar
*.zip
*.7z

# Keystore / secrets (ВАЖНО)
*.keystore
*.jks
*.key
*.pem

# Addressables cache (часто можно игнорировать)
**/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*
**/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.json*
