[Ll]ogs/
[Mm]emoryCaptures/

# User-specific settings
[Uu]serSettings/

# IDE / OS
.vs/
.vscode/
.idea/
*.user
*.userprefs
*.suo
*.tmp
*.swp
*.bak
.DS_Store
Thumbs.db

# Visual Studio / Rider generated
*.csproj
*.unityproj
*.sln
*.suo
*.pidb
*.booproj
